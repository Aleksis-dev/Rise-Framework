<?php

require_once __DIR__ . "/App/autoload/Autoloader.php";

use App\Rise\Core\CLI\Rise;

$rise = new Rise();

if ($argc-1 == 0) {
    exit(0);
}

$splitArg = explode(":", $argv[1]);

if (count($splitArg) >= 2) {
    $splitArg[1] = ucfirst($splitArg[1]);
}

$argv[1] = implode("", $splitArg);

$args = array_slice($argv, 2);

$rise->{$argv[1]}(...$args);